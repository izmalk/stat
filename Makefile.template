# Tutorial test script generation and execution.
#
# Copy this file into your tests/tutorial/ directory (or similar) and
# customise the variables below.
#
# Run from the project root:
#   make -f tests/tutorial/Makefile
#
# Or from the tests/tutorial/ directory:
#   make

# ---------------------------------------------------------------------------
# Python interpreter
# ---------------------------------------------------------------------------
PYTHON   ?= python3

# ---------------------------------------------------------------------------
# Path variables
# ---------------------------------------------------------------------------
THIS_DIR := $(dir $(abspath $(lastword $(MAKEFILE_LIST))))

# TODO: Adjust the number of parent levels to reach your project root.
# If this Makefile lives at tests/tutorial/Makefile, two levels up is correct.
ROOT     := $(abspath $(THIS_DIR)/../..)

EXTRACT  := $(THIS_DIR)extract_commands.py

# TODO: Set the tutorial source directory (relative to project root).
TUTORIAL_SRC := $(ROOT)/docs/tutorial

# Output directory for generated scripts (alongside this Makefile).
TASKS_DIR := $(THIS_DIR)tasks

# ---------------------------------------------------------------------------
# Script → Markdown mapping (SCRIPTS)
# ---------------------------------------------------------------------------
# Each entry is a colon-separated pair:  output.sh:source.md
# Execution order is determined by the ``priority`` field in each file's
# ``<!-- test:spread ... -->`` metadata block.
#
# NOTE: With directory discovery mode (recommended), you don't need to list
# individual files here. The `extract` target auto-discovers all .md files
# with spread metadata. Only define SCRIPTS if you need fine-grained control.
#
# TODO: Uncomment and customise if you need explicit pairs instead of discovery.
# SCRIPTS := \
#     $(TASKS_DIR)/setup.sh:$(TUTORIAL_SRC)/setup.md \
#     $(TASKS_DIR)/deploy.sh:$(TUTORIAL_SRC)/deploy.md \
#     $(TASKS_DIR)/cleanup.sh:$(TUTORIAL_SRC)/cleanup.md
#
# OUTPUTS := $(foreach pair,$(SCRIPTS),$(word 1,$(subst :, ,$(pair))))

# ---------------------------------------------------------------------------
# rel — convert an absolute path to a root-relative path
# ---------------------------------------------------------------------------
rel = $(patsubst $(ROOT)/%,%,$(1))

# ---------------------------------------------------------------------------
# Target: extract  (directory discovery — recommended)
# ---------------------------------------------------------------------------
# Auto-discovers all .md files with <!-- test:spread --> metadata.
.PHONY: extract
extract:
	cd $(ROOT) && $(PYTHON) $(call rel,$(EXTRACT)) $(call rel,$(TUTORIAL_SRC))/ $(call rel,$(TASKS_DIR))/

# ---------------------------------------------------------------------------
# Spread configuration
# ---------------------------------------------------------------------------
SPREAD     ?= spread
# The job selector. With spread.yaml in tests/tutorial/, tasks are under ./tasks/.
SPREAD_JOB ?= multipass:ubuntu-24.04-64:tasks/

# ---------------------------------------------------------------------------
# Target: test  (abort on first failure)
# ---------------------------------------------------------------------------
.PHONY: test
test: extract
	cd $(THIS_DIR) && $(SPREAD) -abend -vv $(SPREAD_JOB)

# ---------------------------------------------------------------------------
# Target: test-continue  (run all stages even if some fail)
# ---------------------------------------------------------------------------
.PHONY: test-continue
test-continue: extract
	cd $(THIS_DIR) && $(SPREAD) -vv $(SPREAD_JOB)

# ---------------------------------------------------------------------------
# Target: test-debug  (abort + interactive shell on failure)
# ---------------------------------------------------------------------------
.PHONY: test-debug
test-debug: extract
	cd $(THIS_DIR) && $(SPREAD) -abend -vv -debug $(SPREAD_JOB)

# ---------------------------------------------------------------------------
# Target: help
# ---------------------------------------------------------------------------
.PHONY: help
help:
	@echo "Usage: make -f tests/tutorial/Makefile [target]"
	@echo ""
	@echo "Targets:"
	@echo "  extract        Regenerate all scripts via directory discovery"
	@echo "  test           Run the tutorial suite (abort on first failure)"
	@echo "  test-continue  Run all stages even if earlier ones fail"
	@echo "  test-debug     Drop into an interactive shell on failure"
	@echo "  help           Show this help message"
